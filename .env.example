# PostgreSQL
POSTGRES_DB=callcenter_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esta_password_segura

# Backend
JWT_SECRET=cambia_esta_clave_secreta_muy_larga_minimo_32_caracteres
LOG_LEVEL=info

# CORS — dominios que pueden acceder a la API
ALLOWED_ORIGINS=http://localhost,https://tudominio.com

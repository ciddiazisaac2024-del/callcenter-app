PORT=3001
DATABASE_URL=postgresql://usuario:password@localhost:5432/callcenter_db
JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria_minimo_32_chars
JWT_EXPIRES_IN=24h
NODE_ENV=development

# CORS: dominios permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Pool de conexiones DB (opcional, defaults: max=10)
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
